# Example of .env
TELEGRAM_TOKEN=put-your-telegram-bot-token-here
ANALYST_CHAT_ID=1057293934

# Proxy (if needed to reach Telegram)
USE_PROXY=true
PROXY_URL=socks5://127.0.0.1:10808

# LLM. false = run offline on the rule-based parser.
USE_LLM=false
MISTRAL_API_KEY=put-your-mistral-key-here
LLM_BASE_URL=https://api.mistral.ai/v1
LLM_MODEL=mistral-small-latest

COLLECTOR_MAX_RETRIES=2
REMINDER_AFTER_SEC=60
ESCALATE_AFTER_SEC=120
ANOMALY_THRESHOLD=0.5
